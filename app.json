{
  "expo": {
    "name": "Just Book It",
    "slug": "Ticket-Booking-System-FE",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-square.png",
    "scheme": "ticketbookingsystemfe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "INTERNET"
      ],
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/app-icon-square.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.atharva1801.TicketBookingSystemFE"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-icon-square.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "apiUrl": "https://movie-booking-ai-agent.vercel.app",
      "eas": {
        "projectId": "5b5e6cdd-6704-4297-bd50-1710e563b7f4"
      }
    }
  }
}
